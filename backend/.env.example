DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=localmind
DB_USERNAME=localmind
DB_PASSWORD=localmind

SESSION_DRIVER=database
SESSION_LIFETIME=120
